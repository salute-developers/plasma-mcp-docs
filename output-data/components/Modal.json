  "examples": [
    {
      "title": "Провайдер контекста",
      "snippet": "import ReactDOM from 'react-dom';\nimport { ModalsProvider } from '@salutejs/plasma-web';\nimport { App } from './App';\nReactDOM.render(\n    <ModalsProvider>\n        <App />\n    </ModalsProvider>,\n    document.getElementById('root')\n);"
    },
    {
      "title": "Вызов модального окна",
      "snippet": "import React from 'react';\nimport { Modal, Headline3, P1, Button } from '@salutejs/plasma-web';\nexport function App() {\n    const [isOpen, setIsOpen] = React.useState(false);\n    const close = React.useCallback(() => {\n      setIsOpen(false);\n    });\n    return (\n        <div>\n            <Button text=\"Открыть модальное окно\" onClick={() => setIsOpen(!isOpen)} />\n            <Modal opened={isOpen} onClose={close}>\n                <Headline3 mb={10}>Модальное окно</Headline3>\n                <P1>Содержимое модального окна.</P1>\n                <Button text=\"Закрыть\" onClick={close} />\n            </Modal>\n        </div>\n    );\n}"
    }
