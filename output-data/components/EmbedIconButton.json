  "examples": [
    {
      "title": "Использование Использование Компонент  EmbedIconButton  может содержать иконку, которая указывается напрямую через  children .",
      "snippet": "import React from 'react';\nimport { EmbedIconButton } from '@salutejs/plasma-web';\nimport { IconClose } from '@salutejs/plasma-icons';\nexport function App() {\n    return (\n        <div>\n            <EmbedIconButton>\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n        </div>\n    );\n}"
    },
    {
      "title": "Размер кнопки",
      "snippet": "import React from 'react';\nimport { EmbedIconButton } from '@salutejs/plasma-web';\nimport { IconClose } from '@salutejs/plasma-icons';\nexport function App() {\n    return (\n        <div>\n            <EmbedIconButton size=\"l\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"m\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n        </div>\n    );\n}"
    },
    {
      "title": "Вид кнопки",
      "snippet": "import React from 'react';\nimport { EmbedIconButton } from '@salutejs/plasma-web';\nimport { IconClose } from '@salutejs/plasma-icons';\nexport function App() {\n    return (\n        <div style={{ display: 'flex', flexWrap: 'wrap' }}>\n            <EmbedIconButton size=\"s\" view=\"default\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"accent\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"secondary\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"clear\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"positive\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"warning\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n            <EmbedIconButton size=\"s\" view=\"negative\">\n                <IconClose color=\"inherit\" />\n            </EmbedIconButton>\n        </div>\n    );\n}"
    }
