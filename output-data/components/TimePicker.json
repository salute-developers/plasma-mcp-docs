  "examples": [
    {
      "title": "Быстрый старт",
      "snippet": "import React from 'react';\nimport { TimePicker } from '@salutejs/plasma-web';\nexport function App() {\n    const handleTimeChange = (event) => {\n        console.log('Выбрано время:', event.target.value);\n    };\n    return (\n        <div style={{height: '500px'}}>\n            <TimePicker\n                view=\"default\"\n                size=\"m\"\n                placeholder=\"00:00:00\"\n                onChange={handleTimeChange}\n            />\n        </div>\n    );\n}"
    },
    {
      "title": "Управление внешним видом и размером компонента",
      "snippet": "import React from 'react';\nimport { TimePicker } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div style={{ display: \"flex\", flexDirection: \"column\", gap: \"32px\"}}>\n            <TimePicker view=\"default\" size=\"l\" placeholder=\"Большой размер\" />\n            <TimePicker view=\"default\" size=\"m\" placeholder=\"Средний размер\" />\n            <TimePicker view=\"default\" size=\"s\" placeholder=\"Маленький размер\" />\n            <TimePicker view=\"default\" size=\"xs\" placeholder=\"Очень маленький размер\" />\n        </div>\n    );\n}"
    },
    {
      "title": "Управление форматом времени (с секундами или без)",
      "snippet": "import React from 'react';\nimport { TimePicker } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div style={{ display: \"flex\", flexDirection: \"column\", gap: \"32px\", height: '500px'}}>\n            <TimePicker size=\"s\" columnsQuantity={2} placeholder=\"ЧЧ:мм\" />\n            <TimePicker size=\"s\" columnsQuantity={3} placeholder=\"ЧЧ:мм:сс\" />\n        </div>\n    );\n}"
    },
    {
      "title": "Расположение выпадающего списка",
      "snippet": "import React from 'react';\nimport { TimePicker } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div style={{ display: \"flex\", flexDirection: \"column\", gap: \"32px\", width: \"300px\", height: '500px'}}>\n            <TimePicker size=\"s\" dropdownAlign=\"left\" placeholder=\"Выравнивание слева\" />\n            <TimePicker size=\"s\" dropdownAlign=\"right\" placeholder=\"Выравнивание справа\" />\n        </div>\n    );\n}"
    }
