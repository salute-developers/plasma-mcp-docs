  "examples": [
    {
      "title": "Использование Использование Компонент  Mask  представляет собой поле ввода с возможностью маскирования значения.",
      "snippet": "import React from 'react';\nimport { Mask } from '@salutejs/plasma-web';\nimport { IconDone } from '@salutejs/plasma-icons';\nexport function App() {\n    return (\n        <div>\n            <Mask\n                label=\"Лейбл\"\n                leftHelper=\"Подсказка к полю\"\n                placeholder=\"Введите дату\"\n                mask=\"00/00/0000\"\n                maskString=\"DD/MM/YYYY\"\n                size=\"l\"\n            />\n        </div>\n    );\n}"
    },
    {
      "title": "Маска Маска Маска задается с помощью свойства  mask .",
      "snippet": "import React from 'react';\nimport { Mask } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div>\n            <Mask\n                label=\"Маска телефона\"\n                placeholder=\"Введите телефон\"\n                mask=\"+7 (000) 000 - 00 - 00\"\n                maskChar=\"_\"\n                size=\"l\"\n                alwaysShowMask\n            />\n        </div>\n    );\n}"
    },
    {
      "title": "Маска Маска Маска задается с помощью свойства  mask .",
      "snippet": "import React from 'react';\nimport { Mask } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div>\n            <Mask\n                label=\"Маска даты\"\n                placeholder=\"Введите дату\"\n                mask=\"00/00/0000\"\n                maskString=\"DD/MM/YYYY\"\n                size=\"l\"\n            />\n        </div>\n    );\n}"
    },
    {
      "title": "Маска Маска Маска задается с помощью свойства  mask .",
      "snippet": "import React from 'react';\nimport { Mask } from '@salutejs/plasma-web';\nexport function App() {\n    return (\n        <div>\n            <Mask\n                label=\"Маска времени\"\n                placeholder=\"Введите время\"\n                mask=\"1\\0:00\"\n                maskChar=\"_\"\n                size=\"l\"\n                showPrefix\n            />\n        </div>\n    );\n}"
